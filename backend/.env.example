# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration (Local SQLite - Default)
DB_TYPE=sqlite
DB_PATH=./data/database.sqlite

# Alternative Database Configuration (MongoDB)
# DB_TYPE=mongodb
# DB_CONNECTION_STRING=mongodb://localhost:27017/information_aggregator_local

# Alternative Database Configuration (PostgreSQL)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=information_aggregator_local
# DB_USER=postgres
# DB_PASSWORD=password

# API Configuration
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=15m

# Search Configuration
SEARCH_TIMEOUT=5000
MAX_SEARCH_RESULTS=100

# External APIs (Optional)
# OPENAI_API_KEY=your_key_here

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ALGOLIA_APP_ID=your_app_id
# ALGOLIA_SEARCH_KEY=your_search_key

# Logging
LOG_LEVEL=debug
